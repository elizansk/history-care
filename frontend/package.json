{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:https": "vite --mode https",
    "build": "tsc -b && vite build",
    "build:pwa": "tsc -b && vite build",
    "build:github": "tsc -b && vite build --mode github-pages && node scripts/prepare-github-pages.mjs",
    "build:tauri": "tsc -b && vite build --mode tauri",
    "deploy:github": "npm run build:github && gh-pages -d dist",
    "generate-api": "npx @openapitools/openapi-generator-cli generate -i ../backend/docs/swagger.json -g typescript-axios -o src/api/generated",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@tauri-apps/api": "^2.11.0",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.14.0",
    "bootstrap": "^5.3.8",
    "react": "^19.1.1",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.1.1",
    "react-redux": "^9.2.0",
    "react-router-bootstrap": "^0.26.3",
    "react-router-dom": "^7.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-bootstrap": "^0.26.8",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-css": "^0.12.0",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-unicorn": "^63.0.0",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.3.0"
  }
}
