<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_HistoryCare" targetNamespace="https://history-care.local/bpmn">
  <bpmn:collaboration id="Collaboration_HistoryCare">
    <bpmn:participant id="Participant_HistoryCare" name="History Care: работа пользователей, заявок, услуг, пожертвований и модерации" processRef="Process_HistoryCare" />
  </bpmn:collaboration>

  <bpmn:process id="Process_HistoryCare" name="Полный бизнес-процесс приложения History Care" isExecutable="false">
    <bpmn:laneSet id="LaneSet_HistoryCare">
      <bpmn:lane id="Lane_Guest" name="Неавторизованный пользователь">
        <bpmn:flowNodeRef>Start_OpenSite</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OpenHome</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_BrowsePublicOrders</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FilterPublicOrders</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ViewPublicOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_GuestGoal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GuestEnterDonation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GuestOpenAuth</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_GuestCanceledPayment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_GuestDonationSaved</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_User" name="Авторизованный пользователь">
        <bpmn:flowNodeRef>Task_UserRegisterOrLogin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UserOpenProfile</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UserEditProfile</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UserBrowseOrders</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UserEnterDonation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_UserProfileUpdated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_UserDonationSaved</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_City" name="Администрация города (City)">
        <bpmn:flowNodeRef>Task_CityRegisterOrLogin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CityOpenProfile</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CityCreateBuilding</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CityGenerateDescription</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CityCreateDraft</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CitySelectServices</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CitySubmitOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CityOpenMyOrders</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_CityOrderAction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CityEditDraft</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CityDeleteDraft</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_CityOrderSent</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Admin" name="Администратор системы">
        <bpmn:flowNodeRef>Task_AdminLogin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AdminOpenPanel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AdminManageServices</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AdminViewUsers</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AdminFilterOrders</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AdminReviewOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AdminDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AdminReturnDraft</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AdminRejectOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AdminDeleteOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AdminCreateOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_AdminServiceManaged</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_AdminUsersViewed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_OrderPublished</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_OrderRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_OrderDeleted</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:dataStoreReference id="DataStore_Users" name="Накопитель: пользователи, роли, JWT" />
    <bpmn:dataStoreReference id="DataStore_CitiesCategories" name="Накопитель: города и категории" />
    <bpmn:dataStoreReference id="DataStore_Buildings" name="Накопитель: здания" />
    <bpmn:dataStoreReference id="DataStore_Media" name="Накопитель: медиафайлы MinIO" />
    <bpmn:dataStoreReference id="DataStore_Services" name="Накопитель: услуги реконструкции" />
    <bpmn:dataStoreReference id="DataStore_Orders" name="Накопитель: заявки, статусы, суммы" />
    <bpmn:dataStoreReference id="DataStore_Donations" name="Накопитель: пожертвования" />
    <bpmn:dataStoreReference id="DataStore_Stripe" name="Накопитель: Stripe Checkout Sessions" />
    <bpmn:dataStoreReference id="DataStore_AI" name="Накопитель: AI/Ollama ответы" />

    <bpmn:startEvent id="Start_OpenSite" name="Пользователь открывает сайт">
      <bpmn:outgoing>Flow_Start_OpenHome</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_OpenHome" name="Просмотреть главную страницу">
      <bpmn:incoming>Flow_Start_OpenHome</bpmn:incoming>
      <bpmn:outgoing>Flow_OpenHome_BrowsePublicOrders</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_BrowsePublicOrders" name="Открыть каталог опубликованных заявок">
      <bpmn:incoming>Flow_OpenHome_BrowsePublicOrders</bpmn:incoming>
      <bpmn:outgoing>Flow_BrowsePublicOrders_Filter</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_FilterPublicOrders" name="Фильтровать заявки по городу, категории и датам">
      <bpmn:incoming>Flow_BrowsePublicOrders_Filter</bpmn:incoming>
      <bpmn:outgoing>Flow_Filter_ViewPublicOrder</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ViewPublicOrder" name="Открыть карточку здания и список услуг">
      <bpmn:incoming>Flow_Filter_ViewPublicOrder</bpmn:incoming>
      <bpmn:outgoing>Flow_ViewPublicOrder_GuestGoal</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_GuestGoal" name="Что сделать дальше?">
      <bpmn:incoming>Flow_ViewPublicOrder_GuestGoal</bpmn:incoming>
      <bpmn:outgoing>Flow_GuestGoal_Donate</bpmn:outgoing>
      <bpmn:outgoing>Flow_GuestGoal_Auth</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_GuestEnterDonation" name="Ввести сумму, имя и email для доната">
      <bpmn:incoming>Flow_GuestGoal_Donate</bpmn:incoming>
      <bpmn:outgoing>Flow_GuestDonation_CreateCheckout</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_GuestOpenAuth" name="Перейти к регистрации или входу">
      <bpmn:incoming>Flow_GuestGoal_Auth</bpmn:incoming>
      <bpmn:outgoing>Flow_OpenAuth_UserAuth</bpmn:outgoing>
      <bpmn:outgoing>Flow_OpenAuth_CityAuth</bpmn:outgoing>
      <bpmn:outgoing>Flow_OpenAuth_AdminAuth</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_UserRegisterOrLogin" name="Зарегистрироваться или войти как пользователь">
      <bpmn:incoming>Flow_OpenAuth_UserAuth</bpmn:incoming>
      <bpmn:outgoing>Flow_UserAuth_Profile</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_UserOpenProfile" name="Открыть личный кабинет">
      <bpmn:incoming>Flow_UserAuth_Profile</bpmn:incoming>
      <bpmn:outgoing>Flow_UserProfile_Edit</bpmn:outgoing>
      <bpmn:outgoing>Flow_UserProfile_BrowseOrders</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_UserEditProfile" name="Изменить имя, фамилию, email или пароль">
      <bpmn:incoming>Flow_UserProfile_Edit</bpmn:incoming>
      <bpmn:outgoing>Flow_UserEdit_End</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="End_UserProfileUpdated" name="Профиль обновлен">
      <bpmn:incoming>Flow_UserEdit_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_UserBrowseOrders" name="Выбрать заявку для помощи">
      <bpmn:incoming>Flow_UserProfile_BrowseOrders</bpmn:incoming>
      <bpmn:outgoing>Flow_UserBrowse_UserDonation</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_UserEnterDonation" name="Выбрать сумму пожертвования">
      <bpmn:incoming>Flow_UserBrowse_UserDonation</bpmn:incoming>
      <bpmn:outgoing>Flow_UserDonation_CreateCheckout</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_CityRegisterOrLogin" name="Зарегистрироваться или войти как City">
      <bpmn:incoming>Flow_OpenAuth_CityAuth</bpmn:incoming>
      <bpmn:outgoing>Flow_CityAuth_Profile</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_CityOpenProfile" name="Открыть профиль и перейти к заявкам">
      <bpmn:incoming>Flow_CityAuth_Profile</bpmn:incoming>
      <bpmn:outgoing>Flow_CityProfile_CreateBuilding</bpmn:outgoing>
      <bpmn:outgoing>Flow_CityProfile_MyOrders</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_CityCreateBuilding" name="Заполнить здание: название, адрес, город, фото">
      <bpmn:incoming>Flow_CityProfile_CreateBuilding</bpmn:incoming>
      <bpmn:incoming>Flow_CityEditDraft_CreateBuilding</bpmn:incoming>
      <bpmn:outgoing>Flow_CreateBuilding_GenerateDescription</bpmn:outgoing>
    </bpmn:task>

    <bpmn:serviceTask id="Task_CityGenerateDescription" name="Сгенерировать описание и категорию через AI">
      <bpmn:incoming>Flow_CreateBuilding_GenerateDescription</bpmn:incoming>
      <bpmn:outgoing>Flow_GenerateDescription_CreateDraft</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_CityCreateDraft" name="Создать или открыть draft-заявку">
      <bpmn:incoming>Flow_GenerateDescription_CreateDraft</bpmn:incoming>
      <bpmn:outgoing>Flow_CreateDraft_SelectServices</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:task id="Task_CitySelectServices" name="Добавить услуги, описания и цены">
      <bpmn:incoming>Flow_CreateDraft_SelectServices</bpmn:incoming>
      <bpmn:outgoing>Flow_SelectServices_SubmitOrder</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_CitySubmitOrder" name="Сформировать заявку и отправить на публикацию">
      <bpmn:incoming>Flow_SelectServices_SubmitOrder</bpmn:incoming>
      <bpmn:outgoing>Flow_SubmitOrder_AdminPanel</bpmn:outgoing>
      <bpmn:outgoing>Flow_SubmitOrder_CityEnd</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_CityOpenMyOrders" name="Открыть список своих заявок">
      <bpmn:incoming>Flow_CityProfile_MyOrders</bpmn:incoming>
      <bpmn:outgoing>Flow_MyOrders_CityAction</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_CityOrderAction" name="Действие с draft-заявкой">
      <bpmn:incoming>Flow_MyOrders_CityAction</bpmn:incoming>
      <bpmn:outgoing>Flow_CityAction_EditDraft</bpmn:outgoing>
      <bpmn:outgoing>Flow_CityAction_DeleteDraft</bpmn:outgoing>
      <bpmn:outgoing>Flow_CityAction_PublishDraft</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_CityEditDraft" name="Редактировать черновик">
      <bpmn:incoming>Flow_CityAction_EditDraft</bpmn:incoming>
      <bpmn:outgoing>Flow_CityEditDraft_CreateBuilding</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_CityDeleteDraft" name="Удалить черновик">
      <bpmn:incoming>Flow_CityAction_DeleteDraft</bpmn:incoming>
      <bpmn:outgoing>Flow_CityDeleteDraft_End</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="End_CityOrderSent" name="Заявка сформирована">
      <bpmn:incoming>Flow_SubmitOrder_CityEnd</bpmn:incoming>
      <bpmn:incoming>Flow_CityAction_PublishDraft</bpmn:incoming>
      <bpmn:incoming>Flow_CityDeleteDraft_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_AdminLogin" name="Войти как администратор системы">
      <bpmn:incoming>Flow_OpenAuth_AdminAuth</bpmn:incoming>
      <bpmn:incoming>Flow_SubmitOrder_AdminPanel</bpmn:incoming>
      <bpmn:outgoing>Flow_AdminLogin_OpenPanel</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AdminOpenPanel" name="Открыть админ-панель">
      <bpmn:incoming>Flow_AdminLogin_OpenPanel</bpmn:incoming>
      <bpmn:outgoing>Flow_AdminPanel_ManageServices</bpmn:outgoing>
      <bpmn:outgoing>Flow_AdminPanel_ViewUsers</bpmn:outgoing>
      <bpmn:outgoing>Flow_AdminPanel_FilterOrders</bpmn:outgoing>
      <bpmn:outgoing>Flow_AdminPanel_CreateOrder</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AdminManageServices" name="Создать услугу с иконкой или удалить услугу">
      <bpmn:incoming>Flow_AdminPanel_ManageServices</bpmn:incoming>
      <bpmn:outgoing>Flow_ManageServices_End</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="End_AdminServiceManaged" name="Справочник услуг обновлен">
      <bpmn:incoming>Flow_ManageServices_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_AdminViewUsers" name="Просмотреть пользователей и роли">
      <bpmn:incoming>Flow_AdminPanel_ViewUsers</bpmn:incoming>
      <bpmn:outgoing>Flow_ViewUsers_End</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="End_AdminUsersViewed" name="Пользователи просмотрены">
      <bpmn:incoming>Flow_ViewUsers_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_AdminFilterOrders" name="Фильтровать заявки по статусу, датам и создателю">
      <bpmn:incoming>Flow_AdminPanel_FilterOrders</bpmn:incoming>
      <bpmn:outgoing>Flow_FilterOrders_Review</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AdminReviewOrder" name="Проверить заявку и действия по статусу">
      <bpmn:incoming>Flow_FilterOrders_Review</bpmn:incoming>
      <bpmn:outgoing>Flow_Review_AdminDecision</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_AdminDecision" name="Решение администратора">
      <bpmn:incoming>Flow_Review_AdminDecision</bpmn:incoming>
      <bpmn:outgoing>Flow_AdminDecision_Publish</bpmn:outgoing>
      <bpmn:outgoing>Flow_AdminDecision_ReturnDraft</bpmn:outgoing>
      <bpmn:outgoing>Flow_AdminDecision_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_AdminDecision_Delete</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AdminReturnDraft" name="Вернуть заявку в черновик">
      <bpmn:incoming>Flow_AdminDecision_ReturnDraft</bpmn:incoming>
      <bpmn:outgoing>Flow_ReturnDraft_CityMyOrders</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AdminRejectOrder" name="Отклонить заявку">
      <bpmn:incoming>Flow_AdminDecision_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_Reject_End</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AdminDeleteOrder" name="Удалить заявку">
      <bpmn:incoming>Flow_AdminDecision_Delete</bpmn:incoming>
      <bpmn:outgoing>Flow_Delete_End</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AdminCreateOrder" name="Создать заявку от имени администратора">
      <bpmn:incoming>Flow_AdminPanel_CreateOrder</bpmn:incoming>
      <bpmn:outgoing>Flow_AdminCreate_CityCreateBuilding</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="End_OrderPublished" name="Заявка опубликована и доступна для пожертвований">
      <bpmn:incoming>Flow_AdminDecision_Publish</bpmn:incoming>
      <bpmn:incoming>Flow_ManageServices_End</bpmn:incoming>
      <bpmn:incoming>Flow_ViewUsers_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="End_OrderRejected" name="Заявка отклонена">
      <bpmn:incoming>Flow_Reject_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="End_OrderDeleted" name="Заявка удалена">
      <bpmn:incoming>Flow_Delete_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:serviceTask id="Service_CreateStripeCheckout" name="Backend создает Stripe Checkout Session">
      <bpmn:incoming>Flow_GuestDonation_CreateCheckout</bpmn:incoming>
      <bpmn:incoming>Flow_UserDonation_CreateCheckout</bpmn:incoming>
      <bpmn:outgoing>Flow_CreateCheckout_PaymentResult</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_PaymentResult" name="Stripe вернул успех?">
      <bpmn:incoming>Flow_CreateCheckout_PaymentResult</bpmn:incoming>
      <bpmn:outgoing>Flow_Payment_Canceled</bpmn:outgoing>
      <bpmn:outgoing>Flow_Payment_SaveDonation</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="End_GuestCanceledPayment" name="Оплата отменена">
      <bpmn:incoming>Flow_Payment_Canceled</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:serviceTask id="Service_SaveDonation" name="Сохранить донат и увеличить collected_amount">
      <bpmn:incoming>Flow_Payment_SaveDonation</bpmn:incoming>
      <bpmn:outgoing>Flow_SaveDonation_TargetCheck</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_TargetCheck" name="Целевая сумма собрана?">
      <bpmn:incoming>Flow_SaveDonation_TargetCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_Target_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_Target_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="End_GuestDonationSaved" name="Донат сохранен, сбор продолжается">
      <bpmn:incoming>Flow_Target_No</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="End_UserDonationSaved" name="Донат сохранен, заявка завершена">
      <bpmn:incoming>Flow_Target_Yes</bpmn:incoming>
      <bpmn:incoming>Flow_UserEdit_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_OpenHome" sourceRef="Start_OpenSite" targetRef="Task_OpenHome" />
    <bpmn:sequenceFlow id="Flow_OpenHome_BrowsePublicOrders" sourceRef="Task_OpenHome" targetRef="Task_BrowsePublicOrders" />
    <bpmn:sequenceFlow id="Flow_BrowsePublicOrders_Filter" sourceRef="Task_BrowsePublicOrders" targetRef="Task_FilterPublicOrders" />
    <bpmn:sequenceFlow id="Flow_Filter_ViewPublicOrder" sourceRef="Task_FilterPublicOrders" targetRef="Task_ViewPublicOrder" />
    <bpmn:sequenceFlow id="Flow_ViewPublicOrder_GuestGoal" sourceRef="Task_ViewPublicOrder" targetRef="Gateway_GuestGoal" />
    <bpmn:sequenceFlow id="Flow_GuestGoal_Donate" name="Помочь объекту" sourceRef="Gateway_GuestGoal" targetRef="Task_GuestEnterDonation" />
    <bpmn:sequenceFlow id="Flow_GuestGoal_Auth" name="Войти или зарегистрироваться" sourceRef="Gateway_GuestGoal" targetRef="Task_GuestOpenAuth" />
    <bpmn:sequenceFlow id="Flow_GuestDonation_CreateCheckout" sourceRef="Task_GuestEnterDonation" targetRef="Service_CreateStripeCheckout" />
    <bpmn:sequenceFlow id="Flow_OpenAuth_UserAuth" name="Роль User" sourceRef="Task_GuestOpenAuth" targetRef="Task_UserRegisterOrLogin" />
    <bpmn:sequenceFlow id="Flow_OpenAuth_CityAuth" name="Роль City" sourceRef="Task_GuestOpenAuth" targetRef="Task_CityRegisterOrLogin" />
    <bpmn:sequenceFlow id="Flow_OpenAuth_AdminAuth" name="Роль Admin" sourceRef="Task_GuestOpenAuth" targetRef="Task_AdminLogin" />
    <bpmn:sequenceFlow id="Flow_UserAuth_Profile" sourceRef="Task_UserRegisterOrLogin" targetRef="Task_UserOpenProfile" />
    <bpmn:sequenceFlow id="Flow_UserProfile_Edit" name="Редактировать профиль" sourceRef="Task_UserOpenProfile" targetRef="Task_UserEditProfile" />
    <bpmn:sequenceFlow id="Flow_UserEdit_End" sourceRef="Task_UserEditProfile" targetRef="End_UserProfileUpdated" />
    <bpmn:sequenceFlow id="Flow_UserProfile_BrowseOrders" name="Сделать донат" sourceRef="Task_UserOpenProfile" targetRef="Task_UserBrowseOrders" />
    <bpmn:sequenceFlow id="Flow_UserBrowse_UserDonation" sourceRef="Task_UserBrowseOrders" targetRef="Task_UserEnterDonation" />
    <bpmn:sequenceFlow id="Flow_UserDonation_CreateCheckout" sourceRef="Task_UserEnterDonation" targetRef="Service_CreateStripeCheckout" />
    <bpmn:sequenceFlow id="Flow_CityAuth_Profile" sourceRef="Task_CityRegisterOrLogin" targetRef="Task_CityOpenProfile" />
    <bpmn:sequenceFlow id="Flow_CityProfile_CreateBuilding" name="Создать заявку" sourceRef="Task_CityOpenProfile" targetRef="Task_CityCreateBuilding" />
    <bpmn:sequenceFlow id="Flow_CityProfile_MyOrders" name="Мои заявки" sourceRef="Task_CityOpenProfile" targetRef="Task_CityOpenMyOrders" />
